rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-+]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidResume(data) {
      return data.name is string && data.name.size() <= 200
        && data.title is string && data.title.size() <= 200
        && data.slogan is string && data.slogan.size() <= 300
        && data.summary is string && data.summary.size() <= 2000
        && data.lastUpdated is string && data.lastUpdated.size() <= 100;
    }

    // Resumes match block
    match /resumes/{username} {
      allow read: if isValidId(username); // Allows get, list, and onSnapshot listeners
      allow create, update: if isValidId(username) && isValidResume(incoming());
      allow delete: if false;
    }

    // Default deny for every other collection.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
