rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-+]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidResume(data) {
      return data.name is string && data.name.size() <= 200
        && data.title is string && data.title.size() <= 200
        && data.slogan is string && data.slogan.size() <= 300
        && data.summary is string && data.summary.size() <= 2000
        && (data.lastUpdated is number || data.lastUpdated is string);
    }

    function isValidChatMessage(data) {
      return data.id is string && data.id.size() <= 128
        && data.sender is string && (data.sender == 'user' || data.sender == 'assistant')
        && data.text is string && data.text.size() <= 10000
        && data.timestamp is string && data.timestamp.size() <= 100;
    }

    // Resumes match block - Allow public read access for resume profiles
    match /resumes/{username} {
      // Allow anyone to read resumes (public profiles)
      // This includes get, list, and real-time listeners (onSnapshot)
      allow get, list: if true;
      
      // Allow create/update with validation
      allow create, update: if isValidId(username) && isValidResume(incoming());
      
      // Never allow delete
      allow delete: if false;
    }

    // Chat history for resume co-pilot - nested under resumes
    match /resumes/{username}/chatHistory/{messageId} {
      // Allow public read for chat history (so resume viewers can see conversation context)
      allow get, list: if true;
      
      // Allow create/update with validation
      allow create, update: if isValidId(username) && isValidChatMessage(incoming());
      
      // Allow delete (for clearing chat history)
      allow delete: if true;
    }

    // AI Career Coach insights - nested under resumes
    match /resumes/{username}/coachInsights/{insightId} {
      // Allow public read for coach insights
      allow get, list: if true;
      
      // Allow create/update (insights are generated and cached)
      allow create, update: if isValidId(username);
      
      // Allow delete (for clearing coach cache)
      allow delete: if true;
    }

    // AI Career Coach chat history - nested under resumes
    match /resumes/{username}/coachChat/{messageId} {
      // Allow public read for coach chat history
      allow get, list: if true;
      
      // Allow create/update with validation
      allow create, update: if isValidId(username) && isValidChatMessage(incoming());
      
      // Allow delete (for clearing coach chat)
      allow delete: if true;
    }

    // Default deny for every other collection.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
